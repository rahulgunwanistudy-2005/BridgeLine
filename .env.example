GOOGLE_API_KEY=
LLM_MAX_CONCURRENCY=1
LLM_MIN_INTERVAL_SECONDS=4.1
LLM_MAX_ATTEMPTS=3
LLM_RETRY_BASE_SECONDS=1.0
DATABASE_URL=postgresql+asyncpg://bridgeline:bridgeline@localhost:5432/bridgeline
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
POSTGRES_DB=bridgeline
POSTGRES_USER=bridgeline
POSTGRES_PASSWORD=bridgeline

# Synthetic-data seed loader (see docs/seed-api-contract.md). Endpoints are gated behind
# SEED_ENABLED on the API side; the loader no-ops until they exist.
SEED_TOKEN=
SEED_STRICT=0
SEED_MAX_WAIT_SECONDS=120
