{
  "name": "@bridgeline/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "codegen": "node --import tsx scripts/codegen.ts",
    "codegen:check": "node --import tsx scripts/codegen.ts --check",
    "fixtures": "node --import tsx scripts/generate-rules-fixture.ts",
    "fixtures:check": "node --import tsx scripts/generate-rules-fixture.ts --check",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "@fontsource/public-sans": "^5.2.5",
    "@fontsource/source-serif-4": "^5.2.5",
    "@tailwindcss/vite": "^4.1.11",
    "lucide-react": "^0.525.0",
    "msw": "^2.10.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.7.1",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
